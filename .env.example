# OpenRouter LLM Configuration
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# Database
DATABASE_URL=postgresql+asyncpg://datacopilot:datacopilot@db:5432/datacopilot
DB_READ_ONLY=true

# File system access
ALLOWED_FILE_PATHS=["/app/sample-data"]

# Server
LOG_LEVEL=INFO
